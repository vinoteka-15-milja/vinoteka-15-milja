# Uvek preusmeri na HTTPS (zadržava www/goli domen kakav jeste)
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Napomena: dev.15milja.com je zaključan svojim .htaccess-om u public_html/dev
# (ne ovde u root-u, da auth ne bi "curio" u druge poddomene/poddirektorijume kao staging).
